<UserControl x:Class="LaserCleanChamber.View.Controls.TracingEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LaserCleanChamber.View.Controls"
             xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
             xmlns:h="http://helix-toolkit.org/wpf"
             xmlns:conv="clr-namespace:LaserCleanChamber.View.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <conv:SideNameConverter x:Key="translateConverter"/>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Margin="4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Margin="4" Grid.Column="0">
                <TextBlock Margin="4" Text="Алгоритм сканирования:"/>
                <ComboBox SelectedIndex="0" MinWidth="200" SelectionChanged="ComboBox_SelectionChanged"
                          BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                          ItemsSource="{Binding TracingAlgorithms, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
                          SelectedItem="{Binding TracingAlgorythm, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}"
                          IsEditable="False">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource translateConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
            
            <StackPanel Orientation="Horizontal" Margin="4" Grid.Column="1" HorizontalAlignment="Right">
                <TextBlock Margin="4" Text="Сторона:"/>
                <ComboBox SelectedIndex="0" MinWidth="80" IsEditable="False"
                          BorderBrush="{DynamicResource MahApps.Brushes.Accent}"
                          ItemsSource="{Binding PlateSides, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
                          SelectedItem="{Binding PlateSide, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource translateConverter}}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
            </StackPanel>
        </Grid>

        <Border BorderThickness="1" BorderBrush="Gray" CornerRadius="6" Grid.Row="1">
            <Border.Background>
                <RadialGradientBrush>
                    <RadialGradientBrush.GradientStops>
                        <GradientStop Color="White"/>
                        <GradientStop Offset="2" Color="LightGray"/>
                    </RadialGradientBrush.GradientStops>
                </RadialGradientBrush>
            </Border.Background>
            <h:HelixViewport3D x:Name="MainViewport" 
                               IsRotationEnabled="True" 
                               ShowCoordinateSystem="True"
                               ShowViewCube="True"
                               
                               MouseDown="MainViewport_MouseDown"
                               MouseMove="MainViewport_MouseMove"
                               MouseUp="MainViewport_MouseUp">
                <ModelVisual3D>
                    <ModelVisual3D.Content>
                        <AmbientLight Color="#404040"/>
                    </ModelVisual3D.Content>
                </ModelVisual3D>
                <ModelVisual3D>
                    <ModelVisual3D.Content>
                        <DirectionalLight Color="LightYellow" Direction="-1,-1,-1" />
                    </ModelVisual3D.Content>
                </ModelVisual3D>
                <!-- Дополнительный свет с другой стороны для объема -->
                <ModelVisual3D>
                    <ModelVisual3D.Content>
                        <DirectionalLight Color="#A0A0A0" Direction="1,1,1" />
                    </ModelVisual3D.Content>
                </ModelVisual3D>

                <!-- Визуализатор STL модели -->
                <ModelVisual3D x:Name="ModelVisualizer">
                </ModelVisual3D>

                <!-- Основной направленный свет (имитация солнца/лампы) -->

                <!-- Сетка пола для масштаба -->
                <h:GridLinesVisual3D Width="400" Length="400" MinorDistance="10" MajorDistance="50" Fill="Gray" />

                <h:HelixViewport3D.Camera>
                    <OrthographicCamera Position="0,0,100" 
                                    LookDirection="0,0,-1" 
                                    UpDirection="0,1,0"
                                    Width="300" NearPlaneDistance="-400" FarPlaneDistance="400"
                                    x:Name="camera"/>
                </h:HelixViewport3D.Camera>
            </h:HelixViewport3D>
        </Border>
    </Grid>
</UserControl>
