<UserControl x:Class="LaserCleanChamber.View.Controls.ChamberIndicators"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LaserCleanChamber.View.Controls"
             xmlns:calc="clr-namespace:CalcBinding;assembly=CalcBinding"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <ScrollViewer VerticalAlignment="Center" VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <local:IndicatorItem Grid.Row="0" Margin="10"
                Header="ДВЕРЦА"
                IsActive="{calc:Binding IsDoorClosed, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
                ActiveText="ЗАКРЫТА"
                InactiveText="ОТКРЫТА"
                InactiveColor="#FF0055"
                ActiveColor="#22C55E"/>

            <local:IndicatorItem Grid.Row="1" Margin="10"
                Header="ФИЛЬЕРА"
                IsActive="{calc:Binding IsPlatePlaced, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
                ActiveText="УСТАНОВЛЕНА"
                InactiveText="ОТСУТСТВУЕТ"
                InactiveColor="#FF0055"
                ActiveColor="#22C55E"/>

            <local:IndicatorItem Grid.Row="2" Margin="10"
                Header="ПИСТОЛЕТ"
                IsActive="{calc:Binding IsPistolPlaced, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
                ActiveText="УСТАНОВЛЕН"
                InactiveText="ОТСУТСТВУЕТ"
                InactiveColor="#FF0055"
                ActiveColor="#22C55E"/>
        </Grid>
    </ScrollViewer>
</UserControl>
