<UserControl x:Class="LaserCleanChamber.View.Controls.ConnectionControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LaserCleanChamber.View.Controls"
             xmlns:ic="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:model="clr-namespace:LaserCleanChamber.Model.Communication"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" d:DataContext="{StaticResource mainViewModel}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="140"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        
        <TextBlock Grid.Column="0" Grid.Row="0" VerticalAlignment="Center" Margin="4"
                   Text="Камера отчистки:"/>
        <ComboBox Grid.Column="0" Grid.Row="1" VerticalAlignment="Center" Margin="4"
                  ItemsSource="{Binding ConnectionViewModel.ComPortInfos, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
                  SelectedItem="{Binding ConnectionViewModel.SelectedChamberDevice, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
                <DataTemplate DataType="{x:Type model:ComPortInfo}">
                    <ContentPresenter Content="{Binding Description}">
                    </ContentPresenter>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
        
        <Button Grid.Column="1" Grid.Row="1" VerticalAlignment="Center" Margin="4" Command="{Binding ConnectionViewModel.RefreshCommand}"
                Style="{DynamicResource MahApps.Styles.Button}">
            <ic:PackIconMaterial Kind="Refresh"/>
        </Button>

        <TextBlock Grid.Column="0" Grid.Row="2" VerticalAlignment="Center" Margin="4"
                   Text="Лазер:"/>
        <ComboBox Grid.Column="0" Grid.Row="3" VerticalAlignment="Center" Margin="4"
                  ItemsSource="{Binding ConnectionViewModel.ComPortInfos, UpdateSourceTrigger=PropertyChanged, Mode=OneWay}"
                  SelectedItem="{Binding ConnectionViewModel.SelectedLaserDevice, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}">
            <ComboBox.ItemTemplate>
                <DataTemplate DataType="{x:Type model:ComPortInfo}">
                    <ContentPresenter Content="{Binding Description}">
                    </ContentPresenter>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <Button Grid.Column="1" Grid.Row="3" VerticalAlignment="Center" Margin="4" Command="{Binding ConnectionViewModel.RefreshCommand}"
                Style="{DynamicResource MahApps.Styles.Button}">
            <ic:PackIconMaterial Kind="Refresh"/>
        </Button>

        <Button Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="4" VerticalAlignment="Center" Margin="4"
                Style="{DynamicResource MahApps.Styles.Button}" Command="{Binding ConnectCommand, UpdateSourceTrigger=PropertyChanged}">
            <StackPanel Orientation="Horizontal">
                <ic:PackIconMaterial Kind="Connection" VerticalAlignment="Center" Margin="0,0,15,0" />
                <TextBlock Text="Подключить" Margin="0 0 25 0"/>
            </StackPanel>
        </Button>
    </Grid>
</UserControl>
