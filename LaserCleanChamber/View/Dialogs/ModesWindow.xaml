<Window x:Class="LaserCleanChamber.View.Dialogs.ModesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LaserCleanChamber.View.Dialogs"
        xmlns:ic="http://metro.mahapps.com/winfx/xaml/iconpacks"
        xmlns:valid="clr-namespace:LaserCleanChamber.View.Validations"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        mc:Ignorable="d" WindowStartupLocation="CenterOwner"
        Title="Настройки сканирования" Height="350" Width="600"
        DataContext="{StaticResource mainViewModel}" Padding="2 2 2 20" Closing="Window_Closing">
    <Window.Resources>
        <valid:RangeRule x:Key="rangeRule"/>
    </Window.Resources>
    <Grid DataContext="{Binding ChamberViewModel.PresetsViewModel}">
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="4" BorderThickness="1" BorderBrush="Gray">
            <DataGrid Background="LightGray"
                      ItemsSource="{Binding Presets, UpdateSourceTrigger=PropertyChanged}" 
                      SelectedItem="{Binding SelectedPreset}"
                      AutoGenerateColumns="False" SelectionMode="Single"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      HeadersVisibility="Column"
                      GridLinesVisibility="Horizontal">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="1.3*"/>
                    
                    <DataGridTemplateColumn Header="Мощность Вт" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Power}" Margin="4,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <mah:NumericUpDown Value="{Binding Power, UpdateSourceTrigger=PropertyChanged}" 
                                   Minimum="{Binding DataContext.MinPower, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                   Maximum="{Binding DataContext.MaxPower, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Ширина (мм)" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ScanWidth}" Margin="4,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <mah:NumericUpDown Value="{Binding ScanWidth, UpdateSourceTrigger=PropertyChanged}" 
                                   Minimum="{Binding DataContext.MinScanWidth, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                   Maximum="{Binding DataContext.MaxScanWidth, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Header="Скорость (мм/с)" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ScanSpeed}" Margin="4,0"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <mah:NumericUpDown Value="{Binding ScanSpeed, UpdateSourceTrigger=PropertyChanged}" 
                                   Minimum="{Binding DataContext.MinScanSpeed, RelativeSource={RelativeSource AncestorType=DataGrid}}"
                                   Maximum="{Binding DataContext.MaxScanSpeed, RelativeSource={RelativeSource AncestorType=DataGrid}}"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <StackPanel Grid.Row="1" Orientation="Horizontal">
            <Button Padding="10 2 10 2" Margin="4" Command="{Binding AddPresetCommandCommand}" MinWidth="120">
                <StackPanel Orientation="Horizontal">
                    <ic:PackIconMaterialDesign VerticalAlignment="Center" Kind="Add" Margin="4"/>
                    <TextBlock Text="СОЗДАТЬ" Margin="4" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Padding="10 2 10 2" Margin="4" Command="{Binding RemovePresetCommandCommand}" MinWidth="120">
                <StackPanel Orientation="Horizontal">
                    <ic:PackIconMaterialDesign VerticalAlignment="Center" Kind="Delete" Margin="4"/>
                    <TextBlock Text="УДАЛИТЬ" Margin="4" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Padding="10 2 10 2" Margin="24 4 4 4" MinWidth="120"
                Command="{Binding ApplyChangesCommand}" Click="Button_Click">
                <StackPanel Orientation="Horizontal">
                    <ic:PackIconMaterialDesign VerticalAlignment="Center" Kind="Check" Margin="4"/>
                    <TextBlock Text="ОК" Margin="4" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <Button Padding="10 2 10 2" Margin="4" MinWidth="120"
                Command="{Binding DiscardChangesCommand}" Click="Button_Click">
                <StackPanel Orientation="Horizontal">
                    <ic:PackIconMaterialDesign VerticalAlignment="Center" Kind="Cancel" Margin="4"/>
                    <TextBlock Text="ОТМЕНА" Margin="4" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </StackPanel>
    </Grid>
</Window>
