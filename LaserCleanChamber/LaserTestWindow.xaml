<Window x:Class="LaserCleanChamber.LaserTestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LaserCleanChamber"
        xmlns:mah="http://metro.mahapps.com/winfx/xaml/controls"
        mc:Ignorable="d"
        Title="LaserTestWindow" Height="450" Width="800">
    <Grid>
        <StackPanel Orientation="Vertical">
            <StackPanel Orientation="Horizontal">
                <ComboBox Margin="4" MinWidth="200" x:Name="cb_ports"/>
                <Button Content="R" Margin="4" Width="40" HorizontalAlignment="Left" x:Name="btn_refresh"
                        Click="btn_refresh_Click"/>
                <Button Content="Connect" Margin="4" MinWidth="80" HorizontalAlignment="Left" x:Name="btn_conn"
                    Click="btn_conn_Click"/>
            </StackPanel>
            <StackPanel Orientation="Vertical" x:Name="stackParamControls">
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="Power, W:" Margin="4" MinWidth="70" VerticalAlignment="Center"/>
                    <mah:NumericUpDown x:Name="nud_power" MinWidth="120" Margin="4"
                                   Minimum="0" Maximum="10000"/>
                    <Button x:Name="set_power" Margin="4" Content="Set"
                        Click="set_power_Click"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="Width, mm:" MinWidth="70" Margin="4" VerticalAlignment="Center"/>
                    <mah:NumericUpDown x:Name="nud_width" MinWidth="120" Margin="4"
                                   Minimum="0.1" Maximum="100"/>
                    <Button x:Name="set_width" Margin="4" Content="Set"
                        Click="set_width_Click"/>
                </StackPanel>
                <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                    <TextBlock Text="Speed, mm/s:" MinWidth="70" Margin="4" VerticalAlignment="Center"/>
                    <mah:NumericUpDown x:Name="nud_speed" MinWidth="120" Margin="4"
                                   Minimum="0" Maximum="1200"/>
                    <Button x:Name="set_speed" Margin="4" Content="Set"
                        Click="set_speed_Click"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
